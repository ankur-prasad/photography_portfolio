# Copy to .env.local and fill in. Vite only exposes vars prefixed with VITE_.

# Supabase — destination for inquiry-form submissions (insert-only via RLS).
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Optional: a generic POST endpoint (Formspree/Web3Forms/serverless) used only
# if the Supabase vars above are unset. If neither is set, the form opens a
# prefilled mail draft as a fallback.
VITE_INQUIRY_ENDPOINT=

# Optional: base URL for full-resolution originals served from an external CDN /
# object store (e.g. Supabase Storage) instead of being committed to public/.
# No trailing slash. The hero depth-scenes load `${VITE_MEDIA_BASE}/photos/<name>`.
# Leave unset to fall back to the bundled, optimized /web/ versions.
# Example: https://<ref>.supabase.co/storage/v1/object/public/photos
VITE_MEDIA_BASE=
